{
  "name": "dandelion",
  "version": "0.0.1",
  "description": "",
  "keywords": [],
  "license": "MIT",
  "author": "SonyPradana",
  "type": "module",
  "scripts": {
    "lint": "oxlint . --deny-warnings",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "clean": "rimraf dist",
    "copy:static": "node scripts/copy-static.js",
    "compile": "rolldown -c",
    "manifest": "node scripts/build-manifest.js",
    "build": "pnpm clean && pnpm compile && pnpm copy:static && pnpm manifest",
    "start:firefox": "pnpm build && web-ext run --source-dir dist"
  },
  "dependencies": {
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.63.0",
    "rimraf": "^6.1.3",
    "rolldown": "^1.0.0",
    "web-ext": "^9.4.0"
  }
}
