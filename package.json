{
  "name": "dandelion",
  "version": "0.0.1",
  "description": "",
  "keywords": [],
  "license": "MIT",
  "author": "SonyPradana",
  "type": "module",
  "scripts": {
    "lint": "oxlint . --deny-warnings",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "clean": "rimraf dist",
    "copy:static": "copyfiles -u 1 src/view/{popup.html,popup.css,/components/KeywordList.css,/components/KeyValueList.css} dist/ && copyfiles -u 1 icons/* dist/icons",
    "rollup": "rollup -c",
    "manifest": "node scripts/build-manifest.js",
    "build": "pnpm clean && pnpm rollup && pnpm copy:static && pnpm manifest",
    "start:firefox": "pnpm build && web-ext run --source-dir dist"
  },
  "dependencies": {
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.9",
    "@rollup/plugin-node-resolve": "^15.3.1",
    "copyfiles": "^2.4.1",
    "dotenv": "^17.4.2",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.2",
    "web-ext": "^9.4.0"
  }
}
